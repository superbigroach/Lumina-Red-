rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read any profile, only edit their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      // Favorites subcollection
      match /favorites/{bizId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Businesses - anyone authed can read, owner can write
    match /businesses/{bizId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.founderId == request.auth.uid;
    }
    // Posts - anyone authed can read, author can write
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // Comments - anyone authed can read/create
    match /posts/{postId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // Likes - anyone authed
    match /posts/{postId}/likes/{likeId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == likeId;
    }
    // Friendships
    match /friendships/{friendId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (resource.data.requesterId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }
    // Transactions
    match /transactions/{txId} {
      allow read: if request.auth != null && (resource.data.backerId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if request.auth != null;
    }
    // Donation badges
    match /badges/{badgeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    // Waitlist — public write (email capture), no public read
    match /waitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Public counters (waitlist count shown on landing page)
    match /counters/{counterId} {
      allow read: if true;
      allow write: if true;
    }

    // Notifications — users can only see and update their own
    match /notifications/{notifId} {
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Messages
    match /conversations/{convoId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }
  }
}
